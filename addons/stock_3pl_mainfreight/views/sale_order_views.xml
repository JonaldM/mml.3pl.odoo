<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_mf_tracking" model="ir.ui.view">
        <field name="name">sale.order.form.mf.tracking</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_line']" position="before">
                <group name="mf_tracking_group" string="Mainfreight Dispatch"
                       attrs="{'invisible': [('x_mf_tracking_url', 'in', [False, ''])]}">
                    <field name="x_mf_delivery_status" string="Delivery Status" readonly="1"
                           attrs="{'invisible': [('x_mf_delivery_status', '=', False)]}"/>
                    <field name="x_mf_tracking_url" widget="url" string="Track Shipment"
                           readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
