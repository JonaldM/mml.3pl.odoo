<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         3pl.connector — Form View
    ================================================================ -->
    <record id="view_3pl_connector_form" model="ir.ui.view">
        <field name="name">3pl.connector.form</field>
        <field name="model">3pl.connector</field>
        <field name="arch" type="xml">
            <form string="3PL Connector">
                <header>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <!-- Smart button box -->
                    <div class="oe_button_box" name="button_box">
                        <button name="%(stock_3pl_core.action_3pl_message_all)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-envelope"
                                context="{'default_connector_id': active_id, 'search_default_connector_id': active_id}">
                            <field name="message_count" widget="statinfo" string="Messages"/>
                        </button>
                    </div>

                    <!-- General identity -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Mainfreight Auckland"/>
                        </h1>
                    </div>

                    <group>
                        <group string="General">
                            <field name="active"/>
                            <field name="priority"/>
                            <field name="warehouse_id"/>
                            <field name="warehouse_partner"/>
                            <field name="transport"/>
                            <field name="environment"/>
                            <field name="region"/>
                        </group>
                        <group string="3PL Identity">
                            <field name="customer_id"/>
                            <field name="warehouse_code"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- REST API page -->
                        <page string="REST API"
                              invisible="transport != 'rest_api'">
                            <group>
                                <field name="api_url" string="API URL"/>
                                <field name="api_secret" string="API Secret" password="True"/>
                            </group>
                        </page>

                        <!-- SFTP page -->
                        <page string="SFTP"
                              invisible="transport != 'sftp'">
                            <group>
                                <field name="sftp_host" string="Host"/>
                                <field name="sftp_port" string="Port"/>
                                <field name="sftp_username" string="Username"/>
                                <field name="sftp_password" string="Password" password="True"/>
                                <field name="sftp_outbound_path" string="Outbound Path"/>
                                <field name="sftp_inbound_path" string="Inbound Path"/>
                            </group>
                            <group string="Host Key Verification">
                                <field name="sftp_host_key" widget="text"
                                       placeholder="hostname key-type base64-key  (from ssh-keyscan)"
                                       invisible="transport != 'sftp'"/>
                            </group>
                        </page>

                        <!-- HTTP POST page -->
                        <page string="HTTP POST"
                              invisible="transport != 'http_post'">
                            <group>
                                <field name="http_post_url" string="HTTP POST URL"/>
                                <field name="http_transport_name" string="Transport Name (UniqueID)"/>
                            </group>
                        </page>

                        <!-- Settings page -->
                        <page string="Settings">
                            <group>
                                <field name="notify_user_id"/>
                                <field name="product_category_ids" widget="many2many_tags"/>
                                <field name="last_soh_applied_at"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         3pl.connector — Tree View
    ================================================================ -->
    <record id="view_3pl_connector_tree" model="ir.ui.view">
        <field name="name">3pl.connector.tree</field>
        <field name="model">3pl.connector</field>
        <field name="arch" type="xml">
            <tree string="3PL Connectors">
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="warehouse_partner"/>
                <field name="transport"/>
                <field name="environment"/>
                <field name="active"/>
                <field name="priority"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================
         3pl.connector — Kanban View
    ================================================================ -->
    <record id="view_3pl_connector_kanban" model="ir.ui.view">
        <field name="name">3pl.connector.kanban</field>
        <field name="model">3pl.connector</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="warehouse_partner"/>
                <field name="environment"/>
                <field name="transport"/>
                <field name="message_count"/>
                <field name="last_soh_applied_at"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span t-if="record.environment.raw_value == 'production'"
                                      class="badge badge-pill badge-danger ml-1">PROD</span>
                                <span t-else=""
                                      class="badge badge-pill badge-secondary ml-1">TEST</span>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <div>
                                    <span class="text-muted">Partner: </span>
                                    <field name="warehouse_partner"/>
                                </div>
                                <div>
                                    <span class="text-muted">Transport: </span>
                                    <field name="transport"/>
                                </div>
                                <div>
                                    <span class="text-muted">Messages: </span>
                                    <field name="message_count"/>
                                </div>
                                <div t-if="record.last_soh_applied_at.raw_value">
                                    <span class="text-muted">Last SOH: </span>
                                    <field name="last_soh_applied_at"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         3pl.connector — Window Action
    ================================================================ -->
    <record id="action_3pl_connector" model="ir.actions.act_window">
        <field name="name">3PL Connectors</field>
        <field name="res_model">3pl.connector</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

</odoo>
